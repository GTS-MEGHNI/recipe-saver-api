{
	# Automatic HTTPS via Let's Encrypt. The site address below is a real,
	# publicly-resolvable hostname (sslip.io maps 137.74.214.52.sslip.io -> the
	# VPS IP), which is all the ACME HTTP-01 challenge needs — no domain purchase.
	# Requires ports 80 (challenge) and 443 (HTTPS) reachable on the host.
	frankenphp
}

137.74.214.52.sslip.io {
	root * /app/public
	encode zstd gzip

	# Serve the Laravel application through FrankenPHP.
	php_server

	log {
		output stdout
		format console
	}
}

# Container-local plaintext endpoint for the Docker healthcheck only (Host:
# localhost, never exposed publicly). `http://` forces plain HTTP so no cert is
# attempted for localhost.
http://localhost {
	root * /app/public
	php_server
}
