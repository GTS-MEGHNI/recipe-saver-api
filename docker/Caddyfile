{
	# TLS is terminated by the host's nginx reverse proxy; the container serves
	# plain HTTP on :80 (published to 127.0.0.1 only). nginx forwards the real
	# client IP via X-Forwarded-For — see bootstrap/app.php trustProxies().
	auto_https off
	frankenphp
}

:80 {
	root * /app/public
	encode zstd gzip

	# Serve the Laravel application through FrankenPHP.
	php_server

	log {
		output stdout
		format console
	}
}
