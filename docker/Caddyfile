{
	# TLS is terminated by the host's nginx reverse proxy; the container serves
	# plain HTTP on :80 (published to 127.0.0.1 only). nginx forwards the real
	# client IP via X-Forwarded-For — see bootstrap/app.php trustProxies().
	auto_https off
	frankenphp

	# Host nginx already writes an access log for every request and terminates
	# TLS, so Caddy's own per-request access log is redundant noise. Keep only
	# WARN+ from Caddy/FrankenPHP itself; Laravel app logs come through PHP's
	# stderr (see LOG_STACK=stderr in docker-compose.yml).
	log {
		level WARN
	}
}

:80 {
	root * /app/public
	encode zstd gzip

	# Serve the Laravel application through FrankenPHP.
	php_server
}
